+function _district_adjacency(instance::Instance, districts::Vector{Vector{Int}})
+    nd = length(districts)
+    adj = [Int[] for _ = 1:nd]
+    neighborPairs = findNeighborDistricts(instance, districts)
+    for (pair, _) in neighborPairs
+        push!(adj[pair[1]], pair[2])
+        push!(adj[pair[2]], pair[1])
+    end
+    return adj
+end
